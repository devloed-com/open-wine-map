__pycache__/
*.pyc
.venv/
.ruff_cache/
.pytest_cache/
.DS_Store
*.log

# secrets — PISTE / Légifrance OAuth credentials, etc.
.env
.env.*
!.env.example

# unrelated projects coexisting in this checkout
wine-wiki/

# raw/ holds downloaded datasets, the pdftotext cache, the cahier-extracted
# JSON, the Wikipedia grape lexicon cache, and the manual translation cache —
# all reproducible from scripts/00…02c. None of it is committed.
raw/

# build-output binaries that may sneak in elsewhere
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.pmtiles
*.zip
*.html

# stage 02c round-trip work files (todo.json emitted by --emit-todo,
# done*.json returned by the translator) — ephemeral
todo.json
done*.json

# generated wiki — stage 03 emits one .md per appellation/DGC + indices;
# wiki/concepts/ is hand-authored and tracked
/wiki/**
!/wiki/concepts/

# obsidian / editor scratch
.obsidian/

# local agent state (settings.json is shared, settings.local.json is per-user)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# gettext catalogs — UI-localisation layer; not committed in the minimal
# bootstrap. Stage 04 falls back to the FR source when these are absent.
locale/

tmp/*
